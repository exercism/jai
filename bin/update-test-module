#!/usr/bin/env bash

# Synopsis:
# Copy the latest extest.jai file to each exercise's test directory as test.jai.
# This is useful when you have made changes to the extest.jai file and want to
# ensure that all exercises are using the latest version.

# Example: update the test module for all exercises
# bin/update-test-module

# Example: update the test module for a single exercise
# bin/update-test-module two-fer

set -eo pipefail

exercise_slug="${1:-*}"
shopt -s nullglob
for exercise_dir in ./exercises/{concept,practice}/${exercise_slug}/; do
    if [[ -d "${exercise_dir}" ]]; then
        slug=$(basename "${exercise_dir}")
        echo "Updating test module for ${slug} exercise..."
        cp ./exercises/shared/extest/extest.jai "${exercise_dir}/extest.jai"
    fi
done
